# === CORE APP ENVIRONMENT ===
DATABASE_URL=""
DIRECT_URL=""
CRON_SECRET=""
ADMIN_PASSWORD=""
# Secreto usado para firmar las cookies de sesión del admin. OBLIGATORIO en producción:
# debe ser un valor aleatorio independiente de ADMIN_PASSWORD (ej: openssl rand -hex 32).
# Si se omite, se reutiliza ADMIN_PASSWORD como fallback (no recomendado).
SESSION_SECRET=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
RESEND_API_KEY=""

# === INTELIGENCIA ARTIFICIAL ===
# Modelo principal LLM que se usa como fallback para resúmenes
OLLAMA_MODEL="qwen3.5:9b"
GEMINI_API_KEY=""
GEMINI_API_KEY_2=""
GEMINI_API_KEY_3=""
AI_HORDE_API_KEY=""

# === TELEGRAM ===
# TELEGRAM_CHAT_ID es para tus pruebas privadas; TELEGRAM_CHANNEL_ID para el canal público.
# Si TELEGRAM_CHANNEL_ID está definido, se usará ese por defecto para publicar artículos.
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_CHANNEL_ID=""

# === BLUESKY ===
BLUESKY_HANDLE=""
BLUESKY_PASSWORD=""

# === BINANCE SQUARE ===
BINANCE_SQUARE_API_KEY=""
MAX_POST_CHARS=900

# === TWITTER/X (API v2) ===
#TWITTER_API_KEY="api-key"
#TWITTER_API_SECRET="api-secret"
#TWITTER_ACCESS_TOKEN="access-token"
#TWITTER_ACCESS_TOKEN_SECRET="access-token-secret"

# Opcional: variable general de prueba
DRY_RUN=false

# ---
# Todas las variables pueden ser comentadas (#) si no se usa el servicio.
# NO compartir ni commitear este archivo con claves productivas.
# Para producción, usar un gestor de secretos adecuado o sistema seguro.